%%{init: {"flowchart": {"nodeSpacing": 35, "rankSpacing": 45, "curve": "basis"}, "theme": "base"}}%%

flowchart TB

    subgraph ROW1[" "]
    direction LR

        subgraph HR["Кадровик"]
        direction TB
            HR1["Получение основания<br/>кадрового изменения"]
            HR2["Проверка данных<br/>сотрудника"]
            HR3{"Данные полные?"}
            HR4["Возврат на уточнение<br/>данных или основания"]
            HR5["Подготовка кадрового<br/>документа вручную"]

            HR1 --> HR2
            HR2 --> HR3
            HR3 -- "нет" --> HR4
            HR4 --> HR2
            HR3 -- "да" --> HR5
        end

        subgraph APR["Руководитель / бухгалтерия"]
        direction TB
            APR1["Согласование изменения<br/>руководителем"]
            APR2["Параллельное уведомление<br/>бухгалтерии"]
            APR3{"Есть замечания?"}
            APR4["Возврат кадровику<br/>на доработку"]
            APR5["Согласование выполнено"]

            APR1 --> APR3
            APR2 --> APR3
            APR3 -- "да" --> APR4
            APR3 -- "нет" --> APR5
        end

    end


    subgraph ROW2[" "]
    direction LR

        subgraph NOTIFY["Оператор уведомлений"]
        direction TB
            N1["Ручное определение<br/>получателей"]
            N2["Проверка email<br/>по спискам и почте"]
            N3["Подготовка текста<br/>уведомления"]
            N4["Отправка вне<br/>единой системы"]
            N5["Ручная отметка<br/>об отправке"]

            N1 --> N2
            N2 --> N3
            N3 --> N4
            N4 --> N5
        end

        subgraph CTRL["Контроль результата"]
        direction TB
            C1{"Уведомление<br/>доставлено?"}
            C2["Повторная отправка<br/>или фиксация ошибки"]
            C3["Ожидание ответа<br/>и сверка статуса"]
            C4["Ручная подготовка<br/>сводной отчётности"]
            C5["Завершение обработки<br/>кадрового изменения"]

            C1 -- "нет" --> C2
            C2 --> C3
            C3 --> C1
            C1 -- "да" --> C4
            C4 --> C5
        end

    end


    HR5 --> APR1
    HR5 --> APR2
    APR4 --> HR2
    APR5 --> N1
    N5 --> C1


    classDef normal fill:#eef6ff,stroke:#2468b2,color:#111;
    classDef decision fill:#fff8d9,stroke:#a57900,color:#111;
    classDef error fill:#fde8e8,stroke:#b52b2b,color:#111;

    class HR1,HR2,HR5,APR1,APR2,APR5,N1,N2,N3,N4,N5,C3,C4,C5 normal;
    class HR3,APR3,C1 decision;
    class HR4,APR4,C2 error;
