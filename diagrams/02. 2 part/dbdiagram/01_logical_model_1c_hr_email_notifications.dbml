Project HR_Email_Notifications_1C {
  database_type: "1C metadata logical model"
  Note: "Логическая модель данных подсистемы кадровых уведомлений"
}

Table Spr_Organizatsii {
  id uuid [pk]
  naimenovanie varchar
}

Table Spr_Podrazdeleniya {
  id uuid [pk]
  organizatsiya_id uuid [ref: > Spr_Organizatsii.id]
  naimenovanie varchar
}

Table Spr_Dolzhnosti {
  id uuid [pk]
  naimenovanie varchar
}

Table Spr_Sotrudniki {
  id uuid [pk]
  podrazdelenie_id uuid [ref: > Spr_Podrazdeleniya.id]
  dolzhnost_id uuid [ref: > Spr_Dolzhnosti.id]
  fio varchar
  email varchar
  aktiven boolean
}

Table Spr_VidyKadrovykhIzmeneniy {
  id uuid [pk]
  naimenovanie varchar
  tip_izmeneniya varchar
  prioritet varchar
  trebuet_uvedomleniya boolean
}

Table Spr_PoluchateliUvedomleniy {
  id uuid [pk]
  fio varchar
  email varchar
  tip_poluchatelya varchar
  aktiven boolean
}

Table Spr_GruppyPoluchateley {
  id uuid [pk]
  naimenovanie varchar
  opisanie text
}

Table Spr_GruppyPoluchateley_Sostav {
  id uuid [pk]
  gruppa_id uuid [ref: > Spr_GruppyPoluchateley.id]
  poluchatel_id uuid [ref: > Spr_PoluchateliUvedomleniy.id]
  kommentariy varchar
}

Table Spr_ShablonyPisem {
  id uuid [pk]
  naimenovanie varchar
  tema varchar
  tekst text
  aktiven boolean
}

Table Spr_PravilaRassylki {
  id uuid [pk]
  naimenovanie varchar
  vid_izmeneniya_id uuid [ref: > Spr_VidyKadrovykhIzmeneniy.id]
  gruppa_poluchateley_id uuid [ref: > Spr_GruppyPoluchateley.id]
  shablon_id uuid [ref: > Spr_ShablonyPisem.id]
  prioritet varchar
  aktiven boolean
}

Table Doc_KadrovoyeIzmenenie {
  id uuid [pk]
  sotrudnik_id uuid [ref: > Spr_Sotrudniki.id]
  vid_izmeneniya_id uuid [ref: > Spr_VidyKadrovykhIzmeneniy.id]
  data_izmeneniya date
  trebuyetsya_uvedomleniye boolean
  status_uvedomleniya varchar
  osnovanie varchar
  kommentariy text
}

Table Doc_KadrovoyeIzmenenie_Poluchateli {
  id uuid [pk]
  document_id uuid [ref: > Doc_KadrovoyeIzmenenie.id]
  poluchatel_id uuid [ref: > Spr_PoluchateliUvedomleniy.id]
  email varchar
  status_uvedomleniya varchar
  kommentariy varchar
}

Table Reg_KadrovyeSobytiya {
  id uuid [pk]
  document_id uuid [ref: > Doc_KadrovoyeIzmenenie.id]
  sotrudnik_id uuid [ref: > Spr_Sotrudniki.id]
  vid_izmeneniya_id uuid [ref: > Spr_VidyKadrovykhIzmeneniy.id]
  period date
  kolichestvo int
}

Table Reg_OtpravlennyeUvedomleniya {
  id uuid [pk]
  document_id uuid [ref: > Doc_KadrovoyeIzmenenie.id]
  sotrudnik_id uuid [ref: > Spr_Sotrudniki.id]
  vid_izmeneniya_id uuid [ref: > Spr_VidyKadrovykhIzmeneniy.id]
  poluchatel_id uuid [ref: > Spr_PoluchateliUvedomleniy.id]
  period date
  email varchar
  status varchar
  kolichestvo int
}

Table Reg_OshibkiOtpravkiUvedomleniy {
  id uuid [pk]
  document_id uuid [ref: > Doc_KadrovoyeIzmenenie.id]
  vid_izmeneniya_id uuid [ref: > Spr_VidyKadrovykhIzmeneniy.id]
  poluchatel_id uuid [ref: > Spr_PoluchateliUvedomleniy.id]
  period date
  opisanie_oshibki varchar
  kolichestvo int
}
